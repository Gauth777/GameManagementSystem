generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Company {
  id           Int      @id @default(autoincrement()) @map("company_id")
  name         String   @map("company_name") @db.VarChar(100)
  headquarters String   @db.VarChar(100)
  foundedYear  Int      @map("founded_year")
  games        Game[]
  createdAt    DateTime @default(now())
  @@map("company")
}

model Game {
  id           Int           @id @default(autoincrement()) @map("game_id")
  name         String        @map("game_name") @db.VarChar(100)
  genre        String        @db.VarChar(50)
  releaseDate  DateTime      @map("release_date")
  companyId    Int           @map("company_id")
  company      Company       @relation(fields: [companyId], references: [id])
  gameModes    GameMode[]
  gameAccounts GameAccount[]
  characters   Character[]
  teams        Team[]
  createdAt    DateTime      @default(now())
  @@map("game")
}

model GameMode {
  id          Int     @id @default(autoincrement()) @map("gamemode_id")
  name        String  @map("mode_name") @db.VarChar(50)
  description String? @db.Text
  gameId      Int     @map("game_id")
  game        Game    @relation(fields: [gameId], references: [id])
  matches     Match[]
  @@map("gamemode")
}

model Player {
  id                  Int                  @id @default(autoincrement()) @map("player_id")
  username            String               @unique @db.VarChar(50)
  email               String               @unique @db.VarChar(100)
  passwordHash        String               @map("password_hash") @db.VarChar(255)
  role                Role                 @default(PLAYER)
  joinDate            DateTime             @default(now()) @map("join_date")
  avatarUrl           String?              @map("avatar_url") @db.VarChar(255)
  gameAccounts        GameAccount[]
  stats               PlayerStats[]
  matchParticipations MatchParticipation[]
  createdAt           DateTime             @default(now())
  @@map("player")
}

enum Role {
  ADMIN
  PLAYER
}

model GameAccount {
  id          Int      @id @default(autoincrement()) @map("account_id")
  playerId    Int      @map("player_id")
  gameId      Int      @map("game_id")
  accountLevel Int     @default(1) @map("account_level")
  createdDate DateTime @default(now()) @map("created_date")
  player      Player   @relation(fields: [playerId], references: [id])
  game        Game     @relation(fields: [gameId], references: [id])
  @@unique([playerId, gameId])
  @@map("gameaccount")
}

model Character {
  id       Int     @id @default(autoincrement()) @map("character_id")
  name     String  @map("character_name") @db.VarChar(50)
  role     String  @map("character_role") @db.VarChar(50)
  gameId   Int     @map("game_id")
  game     Game    @relation(fields: [gameId], references: [id])
  imageUrl String? @map("image_url") @db.VarChar(255)
  @@map("character")
}

model Team {
  id             Int                  @id @default(autoincrement()) @map("team_id")
  name           String               @map("team_name") @db.VarChar(100)
  gameId         Int                  @map("game_id")
  game           Game                 @relation(fields: [gameId], references: [id])
  createdDate    DateTime             @default(now()) @map("created_date")
  logoUrl        String?              @map("logo_url") @db.VarChar(255)
  participations MatchParticipation[]
  @@map("team")
}

model Tournament {
  id        Int              @id @default(autoincrement()) @map("tournament_id")
  name      String           @map("tournament_name") @db.VarChar(100)
  startDate DateTime         @map("start_date")
  endDate   DateTime         @map("end_date")
  prizePool Decimal          @map("prize_pool") @db.Decimal(12, 2)
  status    TournamentStatus @default(UPCOMING)
  matches   Match[]
  createdAt DateTime         @default(now())
  @@map("tournament")
}

enum TournamentStatus {
  UPCOMING
  ONGOING
  COMPLETED
}

model Match {
  id             Int                  @id @default(autoincrement()) @map("match_id")
  matchDate      DateTime             @map("match_date")
  matchType      String               @map("match_type") @db.VarChar(50)
  gameModeId     Int                  @map("gamemode_id")
  tournamentId   Int?                 @map("tournament_id")
  gameMode       GameMode             @relation(fields: [gameModeId], references: [id])
  tournament     Tournament?          @relation(fields: [tournamentId], references: [id])
  participations MatchParticipation[]
  playerStats    PlayerStats[]
  createdAt      DateTime             @default(now())
  @@map("match")
}

model MatchParticipation {
  id       Int         @id @default(autoincrement()) @map("participation_id")
  matchId  Int         @map("match_id")
  teamId   Int         @map("team_id")
  playerId Int         @map("player_id")
  result   MatchResult @default(PENDING)
  match    Match       @relation(fields: [matchId], references: [id])
  team     Team        @relation(fields: [teamId], references: [id])
  player   Player      @relation(fields: [playerId], references: [id])
  @@map("matchparticipation")
}

enum MatchResult {
  WIN
  LOSS
  DRAW
  PENDING
}

model PlayerStats {
  id       Int    @id @default(autoincrement()) @map("stats_id")
  playerId Int    @map("player_id")
  matchId  Int    @map("match_id")
  score    Int    @default(0)
  kills    Int    @default(0)
  deaths   Int    @default(0)
  assists  Int    @default(0)
  player   Player @relation(fields: [playerId], references: [id])
  match    Match  @relation(fields: [matchId], references: [id])
  @@map("playerstats")
}
